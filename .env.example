# Copy to .env (or .env.local) and fill in. Real values live in Vercel, never here.
# .env / .env.local are gitignored; this example holds placeholders only.

# Public site URL — used for canonical / sitemap / OpenGraph absolute URLs.
NEXT_PUBLIC_SITE_URL=https://cefabmanagement.com

# Google Analytics 4 Measurement ID (the "G-..." value, NOT the numeric property ID).
# A default is baked into app/layout.tsx; set this to override per environment
# (e.g. leave empty to disable GA). GA is auto-disabled on Vercel Preview deploys.
NEXT_PUBLIC_GA_ID=

# Brevo transactional email (server-only secrets — never NEXT_PUBLIC_*).
BREVO_API_KEY=
BREVO_FROM_NAME=Catherine Cruickshank · CFO/COO
BREVO_FROM_ADDRESS=noreply@cefabmanagement.com
# Recipient of contact-form submissions (override to test). Falls back to the
# production address in lib/brevo.ts when unset.
CONTACT_TO_ADDRESS=

# Google reCAPTCHA v3. Only the SITE key is public (NEXT_PUBLIC_*); the SECRET
# key is server-only. Without these, captcha verification is skipped (dev).
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
RECAPTCHA_MIN_SCORE=0.5
