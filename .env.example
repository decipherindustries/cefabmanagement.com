# No secrets required yet. Contact form is front-end only.
# Future: CONTACT_FORM_ENDPOINT, RESEND_API_KEY, etc.

# Absolute base URL used for canonical/sitemap/OpenGraph URLs.
NEXT_PUBLIC_SITE_URL=https://cefabmanagement.com

# Google Analytics 4 Measurement ID (the "G-..." value, NOT the numeric property ID).
# Defaults to the baked-in ID in app/layout.tsx; set this to override per environment
# (e.g. leave empty in a preview env to disable GA there).
NEXT_PUBLIC_GA_ID=G-FKVV7HJ6MQ

# Brevo transactional email (server-only secrets — never NEXT_PUBLIC_*)
BREVO_API_KEY=xkeysib-XXXX
BREVO_FROM_NAME=Catherine Cruickshank · CFO/COO
BREVO_FROM_ADDRESS=noreply@cefabmanagement.com
CONTACT_TO_ADDRESS=catherine@cefabmanagement.com

# Google reCAPTCHA v3
# Only the SITE key is public (NEXT_PUBLIC_*); the SECRET key is server-only.
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
RECAPTCHA_MIN_SCORE=0.5

